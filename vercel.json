{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/cases/?",
      "dest": "/cases.html"
    },
    {
      "src": "/solutions/?",
      "dest": "/solutions.html"
    },
    {
      "src": "/price/?",
      "dest": "/price.html"
    },
    {
      "src": "/knowledge/?",
      "dest": "/knowledge.html"
    },
    {
      "src": "/about/?",
      "dest": "/about.html"
    },
    {
      "src": "/contact/?",
      "dest": "/contact.html"
    },
    {
      "src": "/geo.html",
      "status": 301,
      "headers": {
        "Location": "/knowledge"
      }
    },
    {
      "src": "/yugong.html",
      "status": 301,
      "headers": {
        "Location": "/about"
      }
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
